<div class="image">
  <%= profile_avatar(entity.user) %>
</div>
<div class="data">
  <div><%= admin_dream_link(entity) %></div>
  <div class="info">
    <%= admin_user_link(entity.user) %>,
    <%= time_tag(entity.created_at) %>
  </div>
  <div class="secondary info">
    <%= entity.body[0..140] %>&hellip;
  </div>
  <% if entity.personal? %>
    <div class="secondary info">
      <%= t('activerecord.attributes.dream.personal') %>
    </div>
  <% end %>
  <div class="secondaty info">
    <%= render partial: 'shared/track', locals: { item: entity } %>
  </div>

  <ul class="actions">
    <li><%= edit_icon(edit_dream_path(id: entity.id)) %></li>
    <li><%= world_icon(dream_path(id: entity.id)) %></li>
  </ul>
</div>
