<div class="data">
  <div><%= admin_pattern_link(entity) %></div>
  <div class="info">
    <%= entity.slug %>
  </div>
  <div class="secondary info">
    <%= t('activerecord.attributes.pattern.language') %>:
    <%= language_name(entity.language) %><br/>
    <%= t(:word_count, count: entity.words_count) %>
  </div>
  <% unless entity.essence.blank? %>
    <div class="secondary info"><%= entity.essence %></div>
  <% end %>

  <ul class="actions">
    <li><%= edit_icon(edit_pattern_path(entity)) %></li>
  </ul>
</div>
