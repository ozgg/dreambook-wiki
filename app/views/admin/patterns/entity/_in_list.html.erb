<div class="image">
  <%= simple_image_preview(entity) %>
</div>
<div class="data">
  <div><%= admin_pattern_link(entity) %></div>
  <div class="info">
    <%= entity.summary %>
  </div>
  <div class="secondary info">
    <%= entity.words_string %>
  </div>

  <ul class="actions">
    <li><%= edit_icon(edit_pattern_path(id: entity.id)) %></li>
  </ul>
</div>
